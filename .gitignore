!data/databases/.gitkeep

# Assets grandes opcionales
assets/videos/*
assets/pdfs/*
!assets/images/.gitkeep
!assets/videos/.gitkeep
!assets/pdfs/.gitkeep
!assets/excels/.gitkeep

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
*.log
