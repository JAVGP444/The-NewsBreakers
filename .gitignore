# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
*.egg-info/

# Node
node_modules/
.next/
out/

# Datos locales (mantener estructura, no archivos pesados)
data/raw/*
data/processed/*
data/databases/*
